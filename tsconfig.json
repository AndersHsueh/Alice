{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "noImplicitAny": false,
    "noEmitOnError": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@qwen-code/qwen-code-core": ["./src/shim/qwen-code-core.ts"],
      "@google/genai": ["./src/shim/google-genai.ts"],
      "@qwen-code/web-templates": ["./src/shim/web-templates.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/acp-integration/**/*",
    "src/nonInteractive/**/*",
    "src/ui/hooks/useGeminiStream.ts",
    "src/ui/hooks/useGeminiStream.test.tsx"
  ]
}
